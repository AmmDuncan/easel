{
  "name": "easel",
  "version": "0.1.0",
  "private": true,
  "description": "A live browser tab for every Claude Code session. The display_push MCP tool appends HTML cards to a scrolling feed you keep open in split-screen.",
  "type": "module",
  "bin": {
    "easel": "bin/easel"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-client.mjs",
    "start": "node dist/cli.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
